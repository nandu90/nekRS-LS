void UDF_Setup()
{
  auto mesh = nrs->meshV;

  if (platform->options.getArgs("RESTART FILE NAME").empty()) {
    for(int n = 0; n < mesh->Nlocal; n++) {
      nrs->U[n + 0 * nrs->fieldOffset] = 1;
      nrs->U[n + 1 * nrs->fieldOffset] = 0;
      nrs->U[n + 2 * nrs->fieldOffset] = 0;
    }
  }
}

