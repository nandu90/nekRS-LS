: ${PROJ_ID:=""}
: ${CPUONLY:=0}
: ${NEKRS_CACHE_BCAST:=0}
: ${NEKRS_SKIP_BUILD_ONLY:=0}
: ${NEKRS_FP32:=0}


case=$1
nodes=$2
time=$3

bin=$NEKRS_HOME/bin/nekrs
if [ $NEKRS_FP32 -gt 0 ]; then
  bin=$NEKRS_HOME/bin/nekrs-fp32
fi

setup() {

ulimit -s unlimited 2>/dev/null

if [ $2 -gt 0 ]; then

  if [ $1 -ne 3 ]; then
    echo "usage: [PROJ_ID] [QUEUE] $0 <casename> <number of compute nodes> <hh:mm>"
    exit 1
  fi

  if [ -z "$PROJ_ID" ]; then
    echo "ERROR: PROJ_ID is empty"
    exit 1
  fi

  if [ -z "$QUEUE" ]; then
    echo "ERROR: QUEUE is empty"
    exit 1
  fi

  if [ ! -f $NEKRS_HOME/bin/nekrs ]; then
    echo "Cannot find" $NEKRS_HOME/bin/nekrs  
    exit 1
  fi

  if [ ! -f $case.par ]; then
    echo "Cannot find" $case.par
    exit 1
  fi

  if [ ! -f $case.udf ]; then
    echo "Cannot find" $case.udf
    exit 1
  fi

  if [ ! -f $case.re2 ]; then
    echo "Cannot find" $case.re2
    exit 1
  fi
fi

}
